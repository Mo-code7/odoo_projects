<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="restaurant_sale_report_view_list" model="ir.ui.view">
        <field name="name">restaurant.sale.report.list</field>
        <field name="model">restaurant.sale.report</field>
        <field name="arch" type="xml">
            <list string="تقرير المبيعات" create="false" edit="false" delete="false">
                <field name="order_date"/>
                <field name="partner_id"/>
                <field name="order_type"/>
                <field name="product_id"/>
                <field name="product_qty" sum="إجمالي الكمية"/>
                <field name="price_subtotal" sum="إجمالي المبيعات" widget="monetary"/>
                <field name="payment_status" widget="badge"
                       decoration-success="payment_status == 'success'"
                       decoration-danger="payment_status == 'failed'"/>
                <field name="order_count" sum="عدد الطلبات"/>
            </list>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="restaurant_sale_report_view_pivot" model="ir.ui.view">
        <field name="name">restaurant.sale.report.pivot</field>
        <field name="model">restaurant.sale.report</field>
        <field name="arch" type="xml">
            <pivot string="تحليل المبيعات" display_quantity="true">
                <field name="order_date"     type="row" interval="day"/>
                <field name="order_type"     type="col"/>
                <field name="price_subtotal" type="measure"/>
                <field name="order_count"    type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="restaurant_sale_report_view_graph" model="ir.ui.view">
        <field name="name">restaurant.sale.report.graph</field>
        <field name="model">restaurant.sale.report</field>
        <field name="arch" type="xml">
            <graph string="رسم بياني للمبيعات" type="bar" stacked="True">
                <field name="order_date"     type="row"     interval="day"/>
                <field name="order_type"     type="col"/>
                <field name="price_subtotal" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Search View -->
    <record id="restaurant_sale_report_view_search" model="ir.ui.view">
        <field name="name">restaurant.sale.report.search</field>
        <field name="model">restaurant.sale.report</field>
        <field name="arch" type="xml">
            <search string="فلترة التقرير">
                <field name="partner_id"/>
                <field name="product_id"/>
                <separator/>
                <filter string="اليوم"    name="today"
                        domain="[('order_date','=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="هذا الأسبوع" name="this_week"
                        domain="[('order_date','&gt;=', (context_today() - datetime.timedelta(days=context_today().weekday())).strftime('%Y-%m-%d'))]"/>
                <filter string="هذا الشهر" name="this_month"
                        domain="[('order_date','&gt;=', context_today().strftime('%Y-%m-01'))]"/>
                <separator/>
                <filter string="دفع ناجح" name="paid_ok"
                        domain="[('payment_status','=','success')]"/>
                <group>
                    <filter string="اليوم" name='group_by_day'      context="{'group_by': 'order_date:day'}"/>
                    <filter string="الشهر" name='group_by_month'      context="{'group_by': 'order_date:month'}"/>
                    <filter string="نوع الطلب" name='group_by_order_type'  context="{'group_by': 'order_type'}"/>
                    <filter string="الصنف" name='group_by_product'      context="{'group_by': 'product_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="restaurant_sale_report_action" model="ir.actions.act_window">
        <field name="name">تقرير المبيعات</field>
        <field name="res_model">restaurant.sale.report</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="search_view_id" ref="restaurant_sale_report_view_search"/>
        <field name="context">{'search_default_this_month': 1}</field>
    </record>

</odoo>
