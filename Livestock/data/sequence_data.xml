<odoo>
    <data noupdate="1">

        <!-- Sequence for Livestock Animal -->
        <record id="seq_poultry_chicken" model="ir.sequence">
            <field name="name">Livestock Animal</field>
            <field name="code">livestock.animal</field>
            <field name="prefix">25</field>    
            <field name="number_next">1</field>
            <field name="padding">3</field>
            <field name="company_id" eval="False"/> <!-- مهم -->
        </record>

        <!-- Sequence for Feeding Record -->
        <record id="seq_feeding_record" model="ir.sequence">
            <field name="name">Feeding Record</field>   
            <field name="code">feeding.record</field> 
            <field name="prefix">food25</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
