<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="point_of_sale.ReceiptScreen" 
       t-inherit="point_of_sale.ReceiptScreen" 
       t-inherit-mode="extension">
        <xpath expr="//button[hasclass('button print')]" position="after">
           <button class="print-receipt btn btn-secondary btn-lg" 
              t-on-click="generatePosReport">
              <i class="fa fa-print me-1"/> تسليم المخزن
           </button>
        </xpath>
    </t>
</templates>
