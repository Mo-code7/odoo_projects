<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="pos_order_template">
        <t t-call="web.html_container"> <t t-call="web.external_layout">
                <div class="page" style="font-family: 'Cairo', sans-serif;">
                    <div class="row mb-4" style="border-bottom: 2px solid #714B67;">
                        <div class="col-6">
                            <h2 style="color: #714B67; font-weight: bold;">إذن تسليم مخزن</h2>
                        </div>
                        <div class="col-6 text-start">
                            <p>
                                <strong>الطلب: </strong>
                                <span t-esc="order_data.get('name') or 'N/A'"/>
                            </p>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-4">
                            <div style="background-color: #f8f9fa; padding: 10px; border-radius: 5px; border-left: 4px solid #714B67;">
                                <strong>تاريخ التقرير:</strong><br/>
                                <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M')"/>
                            </div>
                        </div>
                    </div>
                    <table class="table table-sm mt-4">
                        <thead>
                            <tr style="background-color: #714B67;">
                                <th class="text-start" style="padding: 10px; color: white;">المنتج</th>
                                <th class="text-center" style="padding: 10px; color: white;">باركود</th>
                                <th class="text-center" style="padding: 10px; color: white;">الكمية</th>
                                <th class="text-center" style="padding: 10px; color: white;">الوزن</th>
                                <th class="text-center" style="padding: 10px; color: white;">الحجم</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="order_data.get('lines')">
                                <tr t-foreach="order_data['lines']" t-as="line" style="border-bottom: 1px solid #dee2e6;">
                                    <td class="text-start" style="padding: 8px;"><span t-esc="line.get('product')" style="font-weight: 500;"/></td>
                                    <td class="text-center text-muted"><span t-esc="line.get('barcode')"/></td>
                                    <td class="text-center" style="padding: 8px;"><span t-esc="line.get('qty')" class="badge rounded-pill bg-light text-dark"/></td>
                                    <td class="text-center" style="padding: 8px;"><span t-esc="line.get('weight')" class="badge rounded-pill bg-light text-dark"/></td>
                                    <td class="text-center" style="padding: 8px;"><span t-esc="line.get('volume')" class="badge rounded-pill bg-light text-dark"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    <div class="row justify-content-center mt-4">
                        <div class="col-4 text-center">
                            <p style="font-size: 0.8rem; color: #666;">
                                تم إنشاء هذا التقرير آلياً من نظام نقطة البيع.
                            </p>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>