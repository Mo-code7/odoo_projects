<odoo>
    <record id="sale_order_form_inherit_exchange" model="ir.ui.view">
        <field name="name">sale.order.form.exchange</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list/field[@name='product_uom_id']" position="after">
                <field name="qty_available" readonly="1"/>
                <field name="exchange_price"/>
                <field name="exchange_last_price"/>
                <field name="static_model"/>
                <field name="min_sale_price"/>
                <field name="total_quantity" decoration-bf="1" decoration-info="1"/>
            </xpath>
            
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="cash_customer_id" options="{'no_create': True, 'no_open': True}"/>
            </xpath>

            <xpath expr="//chatter" position="replace"/>
            <!-- نضيفه داخل الـ sheet -->
            <xpath expr="//sheet" position="inside">
                <chatter/>
            </xpath>
        </field>
    </record>

    <record id="account_move_cash_customer_view" model="ir.ui.view">
        <field name="name">account.move.cash.customer.view</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- إضافة زر ذكي (Smart Button) للشحنة -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_delivery" type="object" class="oe_stat_button" icon="fa-truck" invisible="delivery_count == 0">
                    <field name="delivery_count" widget="statinfo" string="التوصيل"/>
                </button>
            </xpath>

            <!-- إضافة زر "تسليم المخزن" في الهيدر -->
            <xpath expr="//header" position="inside">
                <button name="action_validate_delivery" string="تسليم المخزن" type="object" class="btn btn-info" invisible="state != 'draft' or move_type != 'out_invoice'"/>
            </xpath>

            <xpath expr="//field[@name='partner_id']/.." position="inside">
                <field name="cash_customer_id" options="{'no_create': False}"/>
            </xpath>
        </field>
    </record>

    <record id="stock_picking_cash_customer_view" model="ir.ui.view">
        <field name="name">stock.picking.cash.customer.view</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="cash_customer_id" options="{'no_create': True, 'no_open': True}"/>
            </xpath>
        </field>
    </record>
</odoo>