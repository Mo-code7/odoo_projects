<odoo>
    <record id="view_item_exchange_form" model="ir.ui.view">
        <field name="name">item.exchange.form</field>
        <field name="model">item.exchange</field>
        <field name="arch" type="xml">
            <form string="بورصة الأصناف">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="price"/>
                            <field name="last_price"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="بنود البورصة">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="price"/>
                                    <field name="last_price"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_item_exchange_tree" model="ir.ui.view">
        <field name="name">item.exchange.tree</field>
        <field name="model">item.exchange</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="price"/>
                <field name="last_price"/>
            </list>
        </field>
    </record>

    <record id="item_exchange_action" model="ir.actions.act_window">
        <field name="name">بورصة الأصناف</field>
        <field name="res_model">item.exchange</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- <menuitem
        id="menu_item_exchange_root"
        name="بورصة الأصناف"
        sequence="10"
        web_icon="item_stock_exchange,static/description/icon.png"/>

    <menuitem
        id="menu_item_exchange"
        name="البورصة"
        parent="menu_item_exchange_root"
        action="item_exchange_action"/> -->
</odoo>