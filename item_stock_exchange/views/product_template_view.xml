<odoo>
    <record id="product_template_exchange_view" model="ir.ui.view">
        <field name="name">product.template.exchange.view</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="after">
                <field name="static_model"/>
                <field name="exchange_price"/>
                <field name="exchange_last_price"/>
                <field name="min_sale_price"/>
            </xpath>
        </field>
    </record>
</odoo>