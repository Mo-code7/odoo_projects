<odoo>
    <record id="property_view_tree" model="ir.ui.view">
        <field name="name">property tree</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <tree class="app_custom" decoration-danger="(is_late)">
                <!-- <header>
                    <button name="property_csv_file" type="object" string="Excel"
                            class="btn-primary"/>
                </header> -->
                <field name="name"/>
                <field name="description"/>
                <field name="postcode"/>
                <field name="is_late" invisible="1"/>
                <field name="owner_id"/>
                <field name="date_available"/>
                <field name="expected_price"/>
                <field name="selling_price"/>
                <field name="bedrooms"/>
                <field name="living_area"/>
                <field name="facades"/>
                <field name="state"/>
                <field name="garage" optional="1"/>
                <field name="garden" optional="1"/>
                <field name="garden_area"/>
                <field name="garden_orientation"/>
            </tree>
        </field>
    </record>
    <record id="property_view_form" model="ir.ui.view">
        <field name="name">property form</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button name="action_open_related_owner"
                                type="object" icon="fa-user" string="Owner"
                                ivisible="not owner_id"/>
                    </div>
                    <widget name="web_ribbon" title="cancel" bg_color="text-bg-danger" invisibe="stat='cancel'"/>
                    <widget name="web_ribbon" title="sold" bg_color="text-bg-success" invisibe="stat='sold'"/>

                    <header>
                        <button name="action" type="object" class="btn_primary" string="Action"/>
                        <button name="action_draft" type="object" class="btn_primary" string="Set to Draft"/>
                        <button name="action_pending" type="object" class="btn_secondary" string="Pending"/>
                        <button name="action_sold" type="object" class="btn_green" string="Sold"/>
                        <button name="action_closed" type="object" class="btn_red" string="Closed"/>
                        <field name="state" widget="statusbar" options="{'clickable':1}"/>
                    </header>
                    <div class="oe_title">
                        <label for="ref"/>
                        <h1>
                            <field name="ref"/>
                        </h1>
                        <label for="name"/>
                        <h3>
                            <field name="name"/>
                        </h3>
                    </div>
                    <group>
                        <group string="General Info">
                            <field name="description"/>
                            <field name="postcode"/>
                            <field name="date_available"/>
                            <field name="expected_selling_date"/>
                            <field name="is_late" invisible="1"/>
                            <field name="expected_price"/>
                            <field name="selling_price"/>
                            <field name="diff"/>
                            <field name="bedrooms"/>
                            <field name="active"/>
                        </group>
                        <group string="Additional Info">
                            <field name="owner_id"/>
                            <field name="owner_address"/>
                            <field name="owner_phone"/>
                            <field name="living_area"/>
                            <field name="facades"/>
                            <field name="garage"/>
                            <field name="garden"/>
                            <field name="garden_area"/>
                            <field name="garden_orientation"/>
                            <field name="tag_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Bedrooms">
                            <field name="line_ids">
                                <tree>
                                    <field name="description"/>
                                    <field name="area"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
            </form>
        </field>
    </record>
     <record id="property_view_search" model="ir.ui.view">
        <field name="name">property search</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <search>
                <field name="postcode"/>
                <field name="name"/>

                <filter name="is_garden" string="With Garden" domain="[('garden','=','True')]"/>
                <filter name="group_garage" string="Garage" context="{'group_by':'garage'}"/>
            </search>
        </field>
    </record>
    <record id="property_action" model="ir.actions.act_window">
        <field name="name">property_action</field>
        <field name="res_model">property</field>
        <field name="view_mode">tree,form,search</field>
    </record>

    <record id="property_closed_server_action" model="ir.actions.server">
        <field name="name">property closed server action</field>
        <field name="model_id" ref="model_property"/>
        <field name="binding_model_id" ref="model_property"/>
        <field name="state">code</field>
        <field name="code">
            action=records.action_closed()
        </field>
    </record>


     <record id="property_change_state_server_action" model="ir.actions.server">
        <field name="name">Change State</field>
        <field name="model_id" ref="model_property"/>
        <field name="binding_model_id" ref="model_property"/>
        <field name="state">code</field>
        <field name="code">
            action=records.action_open_change_state_wizard()
        </field>
    </record>

    <record id="check_selling_date" model="ir.cron">
        <field name="name">Check Expected Selling Date</field>
        <field name="model_id" ref="model_property"/>
        <field name="state">code</field>
        <field name="code">model.check_expected_selling_date()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">true</field>
    </record>
    <menuitem
            id="property_menu_item"
            name="Properties"
            parent="properties_menu"
            action="property_action"
    />

    <record id="list_view_action" model="ir.actions.client">
        <field name="name">Properties List View </field>
        <field name="tag">app_one.action_list_view</field>
    </record>

     <menuitem
            id="list_view_property_menu"
            name="Properties OWL "
            parent="properties_menu"
            action="list_view_action"
    />
</odoo>

