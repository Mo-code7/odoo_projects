<odoo>
    <record id="owner_view_tree" model="ir.ui.view">
        <field name="name">owner.tree</field>
        <field name="model">owner</field>
        <field name="arch" type="xml">
            <tree>
                <field name="owner"/>
                <field name="phone"/>
                <field name="address"/>
            </tree>
        </field>
    </record>
    <record id="owner_view_form" model="ir.ui.view">
        <field name="name">owner.form</field>
        <field name="model">owner</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="owner"/>
                        <h1>
                            <field name="owner"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="phone"/>
                            <field name="address"/>
                        </group>
                       
                       <group>
                           <field name="property_ids" widget="many2many_tags">
                                <tree editable="bottom">
                                    <field name="name"/>
                                </tree>
                           </field>
                       </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="owner_action" model="ir.actions.act_window">
        <field name="name">owner_action</field>
        <field name="res_model">owner</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem
            id="owner_menu_item"
            name="owners"
            parent="configuration_menu"
            action="owner_action"
    />
</odoo>
