<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_smart_contract_expiry_check" model="ir.cron">
            <field name="name">Smart Contract: Expiry Check &amp; Renewal Alarm</field>
            <field name="model_id" ref="model_smart_contract"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_expiring_contracts()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>