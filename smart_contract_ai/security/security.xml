<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Module Category -->
        <record id="module_category_smart_contract" model="ir.module.category">
            <field name="name">Smart Contract Management</field>
            <field name="description">Helps manage custom client agreements and subscription terms.</field>
            <field name="sequence">10</field>
        </record>

        <!-- Security Groups -->
        <record id="group_contract_user" model="res.groups">
            <field name="name">Contract User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_contract_manager" model="res.groups">
            <field name="name">Contract Manager / Officer</field>
            <field name="implied_ids" eval="[(4, ref('group_contract_user'))]"/>
            <field name="all_user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <!-- Record Rules -->
        <!-- Portal User Access Rule: Customers can only see their own contracts -->
        <record id="smart_contract_portal_rule" model="ir.rule">
            <field name="name">Portal Users: Own Contracts Only</field>
            <field name="model_id" ref="model_smart_contract"/>
            <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Internal User Access Rule: Access to all contracts -->
        <record id="smart_contract_internal_user_rule" model="ir.rule">
            <field name="name">Internal Users: All Contracts</field>
            <field name="model_id" ref="model_smart_contract"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_contract_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>