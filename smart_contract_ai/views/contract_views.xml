<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Search View -->
    <record id="view_smart_contract_search" model="ir.ui.view">
        <field name="name">smart.contract.search</field>
        <field name="model">smart.contract</field>
        <field name="arch" type="xml">
            <search string="Contracts Search">
                <field name="name"/>
                <field name="partner_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Active" name="active" domain="[('state', '=', 'open')]"/>
                <filter string="Pending Renewal" name="pending_renewal" domain="[('state', '=', 'pending_renewal')]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group>
                    <filter string="Client" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- List View -->
    <record id="view_smart_contract_tree" model="ir.ui.view">
        <field name="name">smart.contract.list</field>
        <field name="model">smart.contract</field>
        <field name="arch" type="xml">
            <list string="Smart Contracts" decoration-info="state == 'draft'" decoration-success="state == 'open'" decoration-warning="state == 'pending_renewal'" decoration-muted="state in ('closed', 'cancelled')">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="contract_term_months"/>
                <field name="total_amount" sum="Total Contract Portfolio Value" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'open'" decoration-warning="state == 'pending_renewal'" decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_smart_contract_form" model="ir.ui.view">
        <field name="name">smart.contract.form</field>
        <field name="model">smart.contract</field>
        <field name="arch" type="xml">
            <form string="Smart Contract">
                <header>
                    <button name="action_confirm" string="Activate Contract" class="oe_highlight" type="object" invisible="state != 'draft'"/>
                    <button name="action_generate_invoice" string="Create Invoice" class="oe_highlight" type="object" invisible="state not in ('open', 'pending_renewal')"/>
                    <button name="action_run_ai_ocr" string="Run AI Analysis" class="btn-info" type="object" icon="fa-magic" invisible="state in ('closed', 'cancelled')"/>
                    <button name="action_send_renewal_reminder" string="Send Renewal Alert" type="object" invisible="state != 'pending_renewal'"/>
                    <button name="action_draft" string="Reset to Draft" type="object" invisible="state not in ('cancelled', 'closed')"/>
                    <button name="action_cancel" string="Cancel Contract" type="object" invisible="state in ('closed', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,pending_renewal,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoices" type="object" class="oe_stat_button" icon="fa-pencil-square-o" invisible="invoice_count == 0">
                            <field name="invoice_count" widget="statinfo" string="Invoices"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group id="left_details">
                            <field name="partner_id" context="{'res_partner_search_mode': 'customer'}" readonly="state in ('closed', 'cancelled')"/>
                            <field name="start_date" readonly="state in ('closed', 'cancelled')"/>
                            <field name="end_date" readonly="state in ('closed', 'cancelled')"/>
                            <field name="contract_term_months"/>
                        </group>
                        <group id="right_details">
                            <field name="currency_id" groups="base.group_multi_currency"/>
                            <field name="total_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="is_signed" readonly="1"/>
                            <field name="signed_by" invisible="not is_signed"/>
                            <field name="signature_date" invisible="not is_signed"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Contract Lines" name="lines">
                            <field name="line_ids" mode="list" readonly="state in ('closed', 'cancelled')">
                                <list editable="bottom">
                                    <field name="product_id" domain="[('sale_ok', '=', True)]"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="price_unit" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="price_subtotal" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="AI Analysis &amp; Input" name="ai_parsing">
                            <group>
                                <field name="raw_contract_text" placeholder="Copy-paste the contract terms or scanned PDF text here..."/>
                            </group>
                            <group string="AI Analytical Report Summary">
                                <field name="ai_summary" nolabel="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_smart_contract_kanban" model="ir.ui.view">
        <field name="name">smart.contract.kanban</field>
        <field name="model">smart.contract</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column o_kanban_project_tasks" quick_create="false">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="total_amount"/>
                <field name="currency_id"/>
                <field name="end_date"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill shadow-sm rounded border">
                            <div class="oe_kanban_details">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title" style="font-size: 1.1em; color: #2C3E50;">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="mt-2 text-muted">
                                    <i class="fa fa-user"></i> <field name="partner_id"/>
                                </div>
                                <div class="mt-1">
                                    <i class="fa fa-money"></i> <strong><field name="total_amount" widget="monetary"/></strong>
                                </div>
                                <div class="mt-1 text-danger" t-if="record.state.raw_value == 'pending_renewal'">
                                    <i class="fa fa-exclamation-triangle"></i> Expiring: <field name="end_date"/>
                                </div>
                                <div class="oe_kanban_bottom_right mt-3">
                                    <field name="activity_ids" widget="kanban_activity"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_smart_contract_pivot" model="ir.ui.view">
        <field name="name">smart.contract.pivot</field>
        <field name="model">smart.contract</field>
        <field name="arch" type="xml">
            <pivot string="Contracts Portfolio Analysis" display_quantity="true">
                <field name="partner_id" type="row"/>
                <field name="state" type="col"/>
                <field name="total_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_smart_contract_graph" model="ir.ui.view">
        <field name="name">smart.contract.graph</field>
        <field name="model">smart.contract</field>
        <field name="arch" type="xml">
            <graph string="Contracts Graph Analysis" type="bar">
                <field name="partner_id"/>
                <field name="total_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Action definition -->
    <record id="action_smart_contract" model="ir.actions.act_window">
        <field name="name">Smart Contracts</field>
        <field name="res_model">smart.contract</field>
        <field name="view_mode">list,kanban,form,pivot,graph</field>
        <field name="search_view_id" ref="view_smart_contract_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first AI-Powered Smart Contract!
            </p>
            <p>
                Manage service level agreements, use AI to parse documents, and run automated subscription billings.
            </p>
        </field>
    </record>
</odoo>